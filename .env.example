# Required for real LLM calls (commit analysis + postmortem generation).
# Free API key: https://aistudio.google.com/apikey (no credit card required)
GEMINI_API_KEY=

# Optional overrides
LLM_MODEL=gemini/gemini-2.5-flash-lite

# Adapter mode: mock (default, no external accounts needed) | real
GITHUB_ADAPTER=mock
SLACK_ADAPTER=mock

# Only needed if GITHUB_ADAPTER=real
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_TOKEN=

# Only needed if SLACK_ADAPTER=real
SLACK_BOT_TOKEN=
